{
  "name": "waifus",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.26-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/dusansimic/devcontainer-features/templ:0": {}
  },
  "postCreateCommand": "go install github.com/air-verse/air@latest && npm install -g @go-task/cli tailwindcss @tailwindcss/cli",
  "forwardPorts": [3000],
  "customizations": {
    "vscode": {
      "extensions": [
        "a-h.templ",
        "bradlc.vscode-tailwindcss",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  }
}
